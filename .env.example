# Turso (libSQL)
# For local dev you can use a file URL: file:./local.db (no auth token needed)
# For production, create a Turso DB and copy URL + token from `turso db show` / `turso db tokens create`
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Shared password league members type to unlock the submit form
LEAGUE_PASSWORD=change-me

# 32+ random bytes used to sign the session cookie (e.g. `openssl rand -base64 48`)
SESSION_SECRET=replace-with-long-random-string
